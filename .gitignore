# project files
# Ignore Rust and build artifacts
target/
build/
trace/
traces/
junk/

# vendored dependencies
vendor/
!vendor/.gitkeep

# runtime artifacts (checkpoints, logs, data, output, databases)
artifacts/
!artifacts/.gitkeep

# generated protobuf bindings
crates/tensorboard/src/tensorboard_generated/

# generated local outputs
*.bin
*.csv
*.png
data/

# local scripts
scripts/*.py
